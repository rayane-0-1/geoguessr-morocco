rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidLeaderboardEntry(data) {
      return data.size() >= 4 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.username is string && data.username.size() <= 100 &&
             data.score is int && data.score >= 0 && data.score <= 50000 &&
             data.lastUpdated is int;
    }

    match /leaderboard/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidLeaderboardEntry(request.resource.data);
      allow delete: if false;
    }
  }
}
